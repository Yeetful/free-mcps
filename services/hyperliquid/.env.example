# All optional — the public Hyperliquid API needs no key.

# Mainnet by default; point both at *.hyperliquid-testnet.xyz for testnet.
# HYPERLIQUID_API_URL=https://api.hyperliquid.xyz
# HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws

# Per-IP rate limit for the free front door (default 60/min).
# RATE_LIMIT_PER_MINUTE=60
