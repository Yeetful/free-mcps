# NEAR Intents 1Click API JWT (docs.near-intents.org → 1Click API → API Keys).
# The API works WITHOUT it, but then charges an extra 0.2% on every swap —
# set it in production.
# NEAR_INTENT_API_KEY=eyJ...

# Override the 1Click API base URL (tests / staging).
# ONECLICK_API_URL=https://1click.chaindefuser.com

# Per-IP rate limit for the free front door (default 60/min).
# RATE_LIMIT_PER_MINUTE=60
