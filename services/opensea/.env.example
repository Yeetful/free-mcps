# OpenSea API key (required for every read tool and the listing relay).
# Get one instantly: curl -X POST https://api.opensea.io/api/v2/auth/keys
# OPENSEA_API_KEY=

# Optional RPC overrides (defaults are the publicnode endpoints — viem's
# default mainnet RPC 429s under light load, same lesson as the lido sibling).
# ETH_RPC_URL=
# BASE_RPC_URL=
# ARBITRUM_RPC_URL=

# Requests per minute per IP before the front door answers 429 (default 60).
# RATE_LIMIT_PER_MINUTE=
