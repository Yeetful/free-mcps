# All optional — the service runs keyless on public endpoints.

# Robinhood Chain RPC. Default: the chain's public endpoint (rate-limited).
# Takes precedence over ALCHEMY_API_KEY when both are set.
#ROBINHOOD_RPC_URL=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_KEY

# With no ROBINHOOD_RPC_URL, an Alchemy key alone also upgrades the RPC
# (slug robinhood-mainnet). Recommended in production.
#ALCHEMY_API_KEY=

# Ethereum L1 RPC — used only by build_bridge_deposit's balance check.
# Default: https://ethereum-rpc.publicnode.com
#ETH_RPC_URL=

# Per-IP rate limit on /mcp + /sse (default 60/min).
#RATE_LIMIT_PER_MINUTE=60

# ── Brokerage (Robinhood Crypto Trading API) — SELF-HOSTED FALLBACK ONLY ──
# The brokerage_* tools talk to a real Robinhood crypto account. On the
# public hosted deployment users bring their own credentials per-request via
# the x-robinhood-api-key + x-robinhood-private-key HTTP headers (which
# always take precedence). Set these ONLY on a private/self-hosted instance —
# on a public deployment they would serve YOUR account to strangers.
# Key pair setup: docs.robinhood.com/crypto/trading ("Creating a key pair").
#ROBINHOOD_API_KEY=rh-api-...
# Base64-encoded 32-byte Ed25519 private-key seed (the "private key" from the
# key-pair script). Never commit or share this value.
#ROBINHOOD_PRIVATE_KEY=
