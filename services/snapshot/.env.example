# Snapshot hub GraphQL is FREE + public — NO upstream key required. An API key
# only raises read rate limits; it is OPTIONAL, held server-side, never exposed
# to paying clients.
# SNAPSHOT_API_KEY=

# Wallet that receives USDC payments on Base. REQUIRED — unset fails loudly so
# revenue never routes to a wrong/fallback address.
PAYMENT_ADDRESS=0xYourBaseWalletHere

# Settlement network. "base" (mainnet) for production; "base-sepolia" for testnet.
# Bazaar / agentic.market only indexes mainnet ("base").
X402_NETWORK=base

# Price charged per call, in USD (facilitator converts to USDC).
X402_PRICE_USD=0.004

# --- Yeetful earn-tracking (OPTIONAL) ---
# When BOTH are set, each settled paid call is reported to your Yeetful
# dashboard so the revenue shows up under "My MCP servers". Fire-and-forget:
# it never slows or breaks a response, and the server runs un-tracked if either
# is missing.
# YEETFUL_API_KEY  — mint at https://www.yeetful.com/dashboard/keys (the yf_…
#                    secret is shown once; keep it server-side, never commit it).
# YEETFUL_MCP_SLUG — your server's slug under "My MCP servers", i.e. the last
#                    path segment of https://www.yeetful.com/servers/<slug>
YEETFUL_API_KEY=
YEETFUL_MCP_SLUG=

# --- Coinbase CDP facilitator (REQUIRED for agentic.market / Bazaar listing) ---
# Bazaar only indexes services settled through the CDP facilitator.
# Create at https://portal.cdp.coinbase.com/access/api
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Optional overrides. Sequencer is the vote-relay target; testnet override is
# https://testnet.seq.snapshot.org for dry runs.
# SNAPSHOT_HUB_URL=https://hub.snapshot.org
# SNAPSHOT_SEQUENCER_URL=https://seq.snapshot.org
