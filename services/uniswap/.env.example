# Uniswap data comes straight from Base RPC — NO upstream API key exists at all.
# Optional: your own RPC endpoint for higher rate limits (default: public Base RPC).
# BASE_RPC_URL=

# Wallet that receives USDC payments on Base. REQUIRED — unset fails loudly so
# revenue never routes to a wrong/fallback address.
PAYMENT_ADDRESS=0xYourBaseWalletHere

# Settlement network. "base" (mainnet) for production; "base-sepolia" for testnet.
# Bazaar / agentic.market only indexes mainnet ("base").
X402_NETWORK=base

# Price charged per call, in USD (facilitator converts to USDC). Quotes are
# pure eth_calls, so this can undercut every indexer-backed pricing API.
X402_PRICE_USD=0.003

# --- Yeetful earn-tracking (OPTIONAL) ---
# When BOTH are set, each settled paid call is reported to your Yeetful
# dashboard under "My MCP servers". Fire-and-forget.
YEETFUL_API_KEY=
YEETFUL_MCP_SLUG=

# --- Coinbase CDP facilitator (REQUIRED for agentic.market / Bazaar listing) ---
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
