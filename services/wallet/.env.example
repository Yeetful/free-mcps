# REQUIRED — the Alchemy API key (same one the website uses). All reads go
# through Alchemy's Data API + per-chain RPC on this key.
# ALCHEMY_API_KEY=...

# Test seams (unit tests point these at fixtures; never needed in prod).
# ALCHEMY_DATA_URL=https://api.g.alchemy.com
# ALCHEMY_RPC_URL_TEMPLATE=https://{net}.g.alchemy.com

# Per-IP rate limit for the free front door (default 60/min).
# RATE_LIMIT_PER_MINUTE=60
